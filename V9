function v5SetTab(id,persist=true){v5State.activeTab=id;document.querySelectorAll('#nav button').forEach(b=>b.classList.toggle('on',b.dataset.tab===id));document.querySelectorAll('.tab').forEach(x=>x.classList.toggle('on',x.id===id));const fn={overview:renderOverview,standings:renderStandings,races:renderRaces,highlights:renderHighlights,circuits:renderCircuits,trophies:renderTrophies,teams:renderTeams,cars:renderCars,sim:renderSim}[id];if(fn)fn();if(persist)v5Save(true)}
const navEl=document.getElementById('nav');navEl.onclick=e=>{const b=e.target.closest('button[data-tab]');if(!b)return;v5SetTab(b.dataset.tab)};
const saveBtn=document.getElementById('ccSave');if(saveBtn){const oldSave=saveBtn.onclick;saveBtn.onclick=e=>{if(oldSave)oldSave.call(saveBtn,e);v5Save(true)}}
const resetBtn=document.getElementById('ccReset');if(resetBtn){const oldReset=resetBtn.onclick;resetBtn.onclick=e=>{let accepted=false;const nativeConfirm=window.confirm;window.confirm=msg=>{accepted=nativeConfirm(msg);return accepted};try{if(oldReset)oldReset.call(resetBtn,e)}finally{window.confirm=nativeConfirm}if(accepted){v5Reset();renderHighlights();renderCircuits();renderTrophies();renderCars();v5SetTab('overview',false)}}}
document.addEventListener('keydown',e=>{if((e.metaKey||e.ctrlKey)&&e.key.toLowerCase()==='s'){v5Save(true)}});
document.title='F1 2026 · Singapore Command Centre V6';
renderRaces();renderHighlights();renderCircuits();renderTrophies();renderCars();v5SetTab(v5State.activeTab||'overview',false);v5StartTrackTour();
