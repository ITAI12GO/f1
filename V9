 window.V7_TROPHIES=V7_TROPHIES;
 const esc=s=>String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
 const categories=[['all','All trophies'],['championship','Championship'],['race','Race weekend'],['performance','Performance'],['academy','F1 Academy']];
 function activeList(){const cat=v5State.trophyCategory||'all';return cat==='all'?V7_TROPHIES:V7_TROPHIES.filter(x=>x.category===cat)}
 function currentTrophy(){
  if(['world','singapore','abudhabi'].includes(v5State.trophy))v5State.trophy='f1-drivers-2025';
  const list=activeList();let t=V7_TROPHIES.find(x=>x.id===v5State.trophy);
  if(!t||!list.some(x=>x.id===t.id)){t=list[0]||V7_TROPHIES[0];v5State.trophy=t.id}
  return t;
 }
 function hotspotMarkup(t){return t.hotspots.map((h,i)=>{
  const fx=h.x>67?' flip-x':'';const fy=h.y>70?' flip-y':'';
  return `<button class="trophy-hotspot ${i===(v5State.trophyHotspot||0)?'on':''}" style="--x:${h.x}%;--y:${h.y}%" data-hotspot="${i}" aria-label="Trophy detail ${i+1}: ${esc(h.title)}" aria-expanded="${i===(v5State.trophyHotspot||0)}">${i+1}</button><div class="trophy-tooltip${fx}${fy}" style="--x:${h.x}%;--y:${h.y}%"><b>${esc(h.title)}</b><span>${esc(h.text)}</span></div>`
 }).join('')}
 function anatomyPanel(t){const i=Math.min(Math.max(+(v5State.trophyHotspot||0),0),t.hotspots.length-1),h=t.hotspots[i];return `<div class="v7-anatomy" id="v7Anatomy"><div class="v7-anatomy-head"><span class="v7-anatomy-num">${i+1}</span><div><div class="k">Interactive trophy anatomy</div><h4>${esc(h.title)}</h4></div></div><p>${esc(h.text)}</p><div class="v7-anatomy-list">${t.hotspots.map((x,n)=>`<button class="${n===i?'on':''}" data-hotspot-jump="${n}">${n+1} · ${esc(x.title)}</button>`).join('')}</div></div>`}
 function render(){
  const root=document.getElementById('trophies');if(!root)return;
  if(!v5State.trophyCategory)v5State.trophyCategory='all';if(v5State.trophyHotspot==null)v5State.trophyHotspot=0;
  const t=currentTrophy(),list=activeList(),idx=list.findIndex(x=>x.id===t.id);
  root.innerHTML=`<h2>Trophy Cabinet<span class="sub">latest major award categories · tap the numbered markers to explore each trophy</span></h2>
   <div class="trophy-v7-toolbar"><span class="k">Category</span>${categories.map(c=>`<button class="trophy-cat ${v5State.trophyCategory===c[0]?'on':''}" data-trophy-cat="${c[0]}">${c[1]}</button>`).join('')}</div>
   <div class="trophy-library">${list.map(x=>`<button class="trophy-mini ${x.id===t.id?'on':''}" data-v7-trophy="${x.id}" aria-label="Open ${esc(x.name)}"><div class="trophy-mini-media"><span class="trophy-latest">${esc(x.status)}</span><img loading="lazy" src="${x.img}" alt="" onerror="this.style.display='none'"></div><div class="trophy-mini-copy"><small>${esc(x.categoryLabel)}</small><b>${esc(x.name)}</b></div></button>`).join('')}</div>
   <div class="trophy-v7-stage">
    <article class="panel v7-trophy-visual" id="v7TrophyVisual"><img id="v7TrophyImage" src="${t.img}" alt="${esc(t.name)}" style="object-fit:${t.fit||'contain'}"><div class="v7-trophy-fallback"><div><b>Official trophy photograph could not load.</b><br><span>Connect to the internet and reopen this item. The trophy facts and anatomy notes remain available.</span></div></div>${hotspotMarkup(t)}<div class="v7-trophy-nav"><button id="v7TrophyPrev" aria-label="Previous trophy">←</button><button id="v7TrophyNext" aria-label="Next trophy">→</button></div></article>
    <article class="panel v7-trophy-detail"><div class="v7-trophy-heading"><div><div class="trophy-eyebrow">${esc(t.eyebrow)}</div><h3>${esc(t.name)}</h3></div><span class="v7-category-badge">${esc(t.categoryLabel)}</span></div><p class="mut" style="font-size:.9rem;margin-top:9px">${esc(t.significance)}</p>
     <div class="v7-holder"><div class="v7-holder-card"><small>Latest holder / recipient</small><b>${esc(t.holder)}</b></div><div class="v7-holder-card"><small>Edition</small><b>${esc(t.edition)}</b></div></div>
     ${anatomyPanel(t)}
     <div class="trophy-facts">${t.facts.map(x=>`<div class="trophy-fact"><small>${esc(x[0])}</small><b>${esc(x[1])}</b></div>`).join('')}</div>
     <div class="k">Documented construction / finish</div><div class="trophy-materials">${t.materials.map(x=>`<span class="material-chip">${esc(x)}</span>`).join('')}</div><div class="v7-material-note">${esc(t.materialNote||'')}</div>
     <div class="v7-source-row"><a class="source-link" href="${t.source}" target="_blank" rel="noopener">Official award source ↗</a>${t.designSource?`<a class="source-link" href="${t.designSource}" target="_blank" rel="noopener">Design and materials ↗</a>`:''}${t.resultsSource?`<a class="source-link" href="${t.resultsSource}" target="_blank" rel="noopener">Latest result ↗</a>`:''}</div>
    </article>
   </div>
   <div class="v7-disclaimer"><b>Scope:</b> This gallery covers the latest documented major Formula 1 championship, Grand Prix, qualifying, season-performance and F1 Academy trophy categories. Individual Grand Prix promoters commission different trophies, so there is no single universal race-winner design. When official symbolism or material information is unavailable, the dashboard labels the description as visual interpretation rather than presenting it as fact.</div>`;
  root.querySelectorAll('[data-trophy-cat]').forEach(b=>b.onclick=()=>{v5State.trophyCategory=b.dataset.trophyCat;v5State.trophyHotspot=0;const next=(b.dataset.trophyCat==='all'?V7_TROPHIES:V7_TROPHIES.filter(x=>x.category===b.dataset.trophyCat))[0];if(next)v5State.trophy=next.id;v5Save(true);render()});
  root.querySelectorAll('[data-v7-trophy]').forEach(b=>b.onclick=()=>{v5State.trophy=b.dataset.v7Trophy;v5State.trophyHotspot=0;v5Save(true);render()});
  function selectHot(n){v5State.trophyHotspot=+n;v5Save(true);render()}
  root.querySelectorAll('[data-hotspot],[data-hotspot-jump]').forEach(b=>b.onclick=e=>{e.stopPropagation();selectHot(b.dataset.hotspot??b.dataset.hotspotJump)});
  document.getElementById('v7TrophyPrev').onclick=()=>{const n=(idx-1+list.length)%list.length;v5State.trophy=list[n].id;v5State.trophyHotspot=0;v5Save(true);render()};
  document.getElementById('v7TrophyNext').onclick=()=>{const n=(idx+1)%list.length;v5State.trophy=list[n].id;v5State.trophyHotspot=0;v5Save(true);render()};
  const visual=document.getElementById('v7TrophyVisual'),img=document.getElementById('v7TrophyImage');
  img.onerror=()=>visual.classList.add('image-failed');
  visual.onmousemove=e=>{if(matchMedia('(prefers-reduced-motion: reduce)').matches||e.target.closest('.trophy-hotspot'))return;const r=visual.getBoundingClientRect(),x=(e.clientX-r.left)/r.width-.5,y=(e.clientY-r.top)/r.height-.5;img.style.transform=`perspective(1000px) rotateY(${x*4}deg) rotateX(${-y*3}deg) translateY(-2px)`};
  visual.onmouseleave=()=>img.style.transform='';
 }
 window.renderTrophies=render;
 render();
})();
