function driverCardV4(d){const t=TEAMS[d.team],photo=DRIVER_PHOTOS[d.code]||'';const born=new Intl.DateTimeFormat('en-SG',{day:'2-digit',month:'short',year:'numeric'}).format(new Date(d.dob+'T00:00:00'));return `<article class="driver driver-v4 team-glow" style="--team:${t.color}"><div class="driver-photo"><div class="fallback">${d.code}</div><img src="${photo}" alt="Official full-body portrait of ${safe(d.name)} in 2026 race suit" loading="lazy" onload="this.previousElementSibling.style.display='none'" onerror="this.style.display='none';this.previousElementSibling.style.display='grid'"></div><div class="driver-body"><div class="driver-head"><div><div class="k">${safe(t.name)}</div><h3 style="margin:3px 0">${d.nat} ${safe(d.name)}</h3></div><span class="driver-no team-text">#${d.num}</span></div><div class="meta"><span>Born <b>${born}</b></span><span>Age <b>${age(d.dob)}</b></span></div><div class="statgrid"><div class="mini"><b class="team-text">${d.pts}</b><span>Points</span></div><div class="mini"><b>${d.stats.wins}</b><span>Wins</span></div><div class="mini"><b>${d.stats.podiums}</b><span>Podiums</span></div><div class="mini"><b>${d.stats.poles}</b><span>Poles</span></div></div></div></article>`}
renderTeams=function(){const target=document.querySelector('#teams');if(!target)return;const focus=V4.teamFocus==='all'?'all':(TEAMS[V4.teamFocus]?V4.teamFocus:'mercedes'),drivers=focus==='all'?official():teamDrivers(focus),focusTeam=focus==='all'?null:TEAMS[focus];target.innerHTML=`<h2>Teams<span class="sub">official logos · compact four-column directory · balanced spacing</span></h2><div class="v4-toolbar panel"><div class="control"><label>Driver Lab focus</label><select id="v4TeamFocus">${teamOptions(focus,true)}</select></div><div class="spacer"></div><span class="mut">Default shows one team’s two drivers to reduce page scrolling.</span></div><div class="team-grid-v4">${constructors().map(teamCard).join('')}</div><h2>Driver Lab<span class="sub">${focus==='all'?'all 22 official portraits':safe(focusTeam.name)+' · 2 drivers'}</span></h2>${focusTeam?`<div class="driver-lab-head panel" style="--team:${focusTeam.color}">${teamLogo(focus,'team-logo driver-lab-logo')}<div><b class="team-text">${safe(focusTeam.name)}</b><div class="mut">${safe(focusTeam.chassis)} · ${safe(focusTeam.pu)} · P${teamPos(focus)} · ${teamPts(focus)} pts</div></div></div>`:''}<div class="driver-grid-v4">${drivers.map(driverCardV4).join('')}</div>`;document.getElementById('v4TeamFocus').onchange=e=>{V4.teamFocus=e.target.value;markDirty();renderTeams()};target.querySelectorAll('[data-focus-team]').forEach(b=>b.onclick=()=>{V4.teamFocus=b.dataset.focusTeam;markDirty();renderTeams();document.querySelector('#teams h2:nth-of-type(2)')?.scrollIntoView({behavior:'smooth',block:'start'})})};
function officialCarStage(k){const t=TEAMS[k],m=TEAM_MEDIA[k];return `<div class="car-stage-v4 ${aero==='straight'?'straight':'corner'} ${energyMode} ${V4.autoTour?'touring':''}" style="--team:${t.color}"><div class="speed-lines"><i></i><i></i><i></i><i></i></div><div class="stage-hud"><span class="hud-chip">TEAM <b>${safe(t.name.split(' ')[0])}</b></span><span class="hud-chip">AERO <b>${aero==='straight'?'STRAIGHT':'CORNER'}</b></span><span class="hud-chip">ERS <b>${energyMode.toUpperCase()}</b></span><span class="hud-chip">CHASSIS <b>${safe(t.chassis)}</b></span></div><div class="official-car-wrap"><img class="official-car" src="${m.car}" alt="Official Formula 1 media image of the ${safe(t.chassis)}" onerror="this.style.display='none';this.nextElementSibling.style.display='block'"><div class="car-fallback"><b>${safe(t.name)}</b>Official car image unavailable while offline.</div></div><button class="hotspot ${hot==='aero'?'on':''}" data-h="aero" style="left:17%;top:55%">1</button><button class="hotspot ${hot==='ers'?'on':''}" data-h="ers" style="left:53%;top:59%">2</button><button class="hotspot ${hot==='pu'?'on':''}" data-h="pu" style="left:65%;top:43%">3</button><button class="hotspot ${hot==='safety'?'on':''}" data-h="safety" style="left:48%;top:32%">4</button></div>`}
function carCardV4(k,pts){const t=TEAMS[k],m=TEAM_MEDIA[k];return `<article class="carcard carcard-v4 team-glow" style="--team:${t.color}"><div class="team-card-head">${teamLogo(k)}<div class="team-title"><h3>${safe(t.chassis)}</h3><small>${safe(t.name)}</small></div><b class="team-text">P${teamPos(k)}</b></div><div class="car-visual-v4"><img src="${m.car}" alt="Official ${safe(t.chassis)} car image" loading="lazy"></div><div class="specrow"><span>Power unit</span><b>${safe(t.pu)}</b></div><div class="specrow"><span>Drivers</span><b class="team-text">${teamDrivers(k).map(d=>d.code).join(' · ')}</b></div><div class="specrow"><span>Points</span><b>${pts}</b></div><button class="smallbtn team-select-btn" data-car-team="${k}">Load in lab</button></article>`}
function pitTeam(k){const t=TEAMS[k];return `<div class="pit-team" style="--team:${t.color}"><div class="pit-team-head">${teamLogo(k)}<div><b class="team-text">${safe(t.name)}</b><div class="mut">${safe(t.chassis)} · ${safe(t.pu)}</div></div></div><div class="specrow"><span>Championship</span><b>P${teamPos(k)}</b></div><div class="specrow"><span>Team points</span><b>${teamPts(k)}</b></div><div class="specrow"><span>Driver points total</span><b>${teamDriverPts(k)}</b></div><div class="specrow"><span>Line-up</span><b>${teamDrivers(k).map(d=>d.code).join(' · ')}</b></div></div>`}
function pitCompare(){const a=V4.compareA,b=V4.compareB,max=Math.max(teamPts(a),teamPts(b),1),driverMax=Math.max(teamDriverPts(a),teamDriverPts(b),1);return `<div class="pit-grid">${pitTeam(a)}<div class="pit-versus"><div class="pit-row" style="--team:${TEAMS[a].color}"><span>${safe(TEAMS[a].name.split(' ')[0])}</span><div class="pit-meter"><i style="--w:${teamPts(a)/max*100}%"></i></div><strong>${teamPts(a)}</strong></div><div class="pit-row" style="--team:${TEAMS[b].color}"><span>${safe(TEAMS[b].name.split(' ')[0])}</span><div class="pit-meter"><i style="--w:${teamPts(b)/max*100}%"></i></div><strong>${teamPts(b)}</strong></div><div class="k" style="text-align:center">Constructor points</div><div class="pit-row" style="--team:${TEAMS[a].color}"><span>${safe(TEAMS[a].name.split(' ')[0])}</span><div class="pit-meter"><i style="--w:${teamDriverPts(a)/driverMax*100}%"></i></div><strong>${teamDriverPts(a)}</strong></div><div class="pit-row" style="--team:${TEAMS[b].color}"><span>${safe(TEAMS[b].name.split(' ')[0])}</span><div class="pit-meter"><i style="--w:${teamDriverPts(b)/driverMax*100}%"></i></div><strong>${teamDriverPts(b)}</strong></div><div class="k" style="text-align:center">Current driver points total</div></div>${pitTeam(b)}</div><div class="pit-note">Public championship information only. The comparison does not invent hidden pace, horsepower or aerodynamic figures.</div>`}
function startTour(){clearInterval(tourTimer);if(!V4.autoTour)return;tourTimer=setInterval(()=>{const keys=allTeams(),i=keys.indexOf(V4.carTeam);V4.carTeam=keys[(i+1)%keys.length];renderCars()},3200)}
