.chip{position:relative;overflow:hidden}.chip:before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--team)}.chip.on{border-color:var(--team)!important;background:color-mix(in srgb,var(--team) 12%,var(--panel2));color:#fff!important}
