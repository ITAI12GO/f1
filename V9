function ccDriverCard(d){const photo=CC_PHOTOS[d.code];return `<article class="driver team-glow" style="--team:${T(d).color}"><div class="driver-card-stripe"></div><div class="driver-photo"><div class="fallback">${d.code}</div><img src="${photo}" data-official="${d.code}" alt="${esc(d.name)} in the official 2026 ${esc(TEAMS[d.team].name)} race suit" loading="lazy" decoding="async" referrerpolicy="no-referrer"><span class="driver-source">Official F1 media</span></div><div class="driver-body"><div class="driver-head"><div><h3 style="margin:0">${d.nat} ${esc(d.name)}</h3><div class="mut team-text">${TEAMS[d.team].name}</div></div><span class="driver-no team-text">#${d.num}</span></div><div class="meta"><span>Born <b>${new Intl.DateTimeFormat('en-SG',{day:'2-digit',month:'short',year:'numeric'}).format(new Date(d.dob+'T00:00:00'))}</b></span><span>Age <b>${age(d.dob)}</b></span></div><div class="statgrid"><div class="mini"><b class="team-text">${d.pts}</b><span>Points</span></div><div class="mini"><b>${d.stats.wins}</b><span>Wins</span></div><div class="mini"><b>${d.stats.podiums}</b><span>Podiums</span></div><div class="mini"><b>${d.stats.poles}</b><span>Poles</span></div></div></div></article>`}
renderTeams=function(){document.querySelector('#teams').innerHTML=`<h2>Teams<span class="sub">one official colour system across cars, drivers and analytics</span></h2><div class="grid g3">${constructors().map((c,i)=>{const t=TEAMS[c.team];return `<article class="team team-glow" style="--team:${t.color}"><div class="barline" style="background:${t.color}"></div><div class="body"><div style="display:flex;justify-content:space-between"><h3 style="margin:0">${t.name}</h3><b class="team-text">P${i+1}</b></div><div class="mut">${t.chassis} · ${t.pu}</div><div class="specrow"><span>Team chief</span><b>${t.chief}</b></div><div class="specrow"><span>Base</span><b>${t.base}</b></div><div class="specrow"><span>Points</span><b class="team-text">${c.pts}</b></div></div></article>`}).join('')}</div><h2>Driver profiles<span class="sub">official 2026 full-body race-suit portraits · birthday · season performance</span></h2><div class="driver-grid">${official().map(ccDriverCard).join('')}</div>`;loadPhotos()};
loadPhotos=function(){document.querySelectorAll('img[data-official]').forEach(img=>{const fallback=img.parentElement.querySelector('.fallback');const show=()=>{img.style.display='block';if(fallback)fallback.style.display='none'};const fail=()=>{img.style.display='none';if(fallback)fallback.style.display='grid';img.parentElement.querySelector('.driver-source').textContent='Offline fallback'};if(img.complete){img.naturalWidth?show():fail()}else{img.addEventListener('load',show,{once:true});img.addEventListener('error',fail,{once:true})}})};

/* ---------- colour-aware car lab ---------- */
renderCars=function(){const t=TEAMS[ccCarTeam]||TEAMS.mercedes;document.querySelector('#cars').innerHTML=`<h2>2026 car laboratory<span class="sub">select a team to apply its official identity to the interactive model</span></h2><div class="cars-hero"><div class="panel car-lab team-glow" style="--team:${t.color}"><div class="controls" style="margin-bottom:9px"><div class="control"><label>Team car</label><select id="carTeam">${Object.entries(TEAMS).map(([k,v])=>`<option value="${k}">${v.name} · ${v.chassis}</option>`).join('')}</select></div></div><div class="modebar"><button data-a="corner" class="${aero==='corner'?'on':''}">Corner Mode</button><button data-a="straight" class="${aero==='straight'?'on':''}">Straight Mode</button><button data-e="recharge" class="${energyMode==='recharge'?'on':''}">Recharge</button><button data-e="boost" class="${energyMode==='boost'?'on':''}">Boost</button><button data-e="overtake" class="${energyMode==='overtake'?'on':''}">Overtake</button></div><div class="car-stage" id="stage" style="--team:${t.color}">${carSVG(t.color)}<button class="hotspot ${hot==='aero'?'on':''}" data-h="aero" style="left:12%;top:52%">1</button><button class="hotspot ${hot==='ers'?'on':''}" data-h="ers" style="left:55%;top:55%">2</button><button class="hotspot ${hot==='pu'?'on':''}" data-h="pu" style="left:67%;top:43%">3</button><button class="hotspot ${hot==='safety'?'on':''}" data-h="safety" style="left:46%;top:28%">4</button></div><div class="hsinfo note" id="hsinfo"></div><div class="energy"><div class="k">Illustrative electrical deployment</div><div class="energyline"><i id="energybar"></i></div><div class="mut" id="energyText"></div></div></div><div class="panel team-identity" style="--team:${t.color}"><h3 style="margin-top:0" class="team-text">${t.name} · ${t.chassis}</h3><div class="specs"><div class="spec"><b>1,900 mm</b><small>maximum body width</small></div><div class="spec"><b>3,400 mm</b><small>maximum wheelbase</small></div><div class="spec"><b>~768 kg</b><small>headline minimum incl. tyres</small></div><div class="spec"><b>350 kW</b><small>MGU-K maximum output</small></div><div class="spec"><b>8.5 MJ/lap</b><small>maximum ERS-K harvesting</small></div><div class="spec"><b>1.6L V6</b><small>turbo-hybrid ICE</small></div></div><div class="note" style="margin-top:12px"><b>Representation rule:</b> the colour and team identity are real; the moving car is an explanatory regulation model, not a claimed reconstruction of confidential team aerodynamics.</div></div></div><h2>2026 team car directory</h2><div class="grid g3">${constructors().map(c=>carCard(c.team,c.pts)).join('')}</div>`;const teamSel=document.getElementById('carTeam');teamSel.value=ccCarTeam;teamSel.onchange=()=>{ccCarTeam=teamSel.value;ccMarkDirty();renderCars()};document.querySelectorAll('[data-a]').forEach(b=>b.onclick=()=>{aero=b.dataset.a;ccMarkDirty();renderCars()});document.querySelectorAll('[data-e]').forEach(b=>b.onclick=()=>{energyMode=b.dataset.e;ccMarkDirty();renderCars()});document.querySelectorAll('[data-h]').forEach(b=>b.onclick=()=>{hot=b.dataset.h;ccMarkDirty();updateCarInfo()});updateCarInfo()};
updateCarInfo=function(){const info={aero:['Active aerodynamics','Front and rear wing elements change configuration between Corner Mode and low-drag Straight Mode.'],ers:['Energy recovery','The MGU-K can harvest up to 8.5 MJ per lap under the technical regulations.'],pu:['Power unit','1.6-litre V6 turbo hybrid, MGU-H removed, with electrical output raised to 350 kW.'],safety:['Safety cell','Revised impact structures and a more demanding safety package accompany the new dimensions.']}[hot];const box=document.getElementById('hsinfo');if(box)box.innerHTML=`<b>${info[0]}</b><br>${info[1]}`;document.querySelectorAll('.hotspot').forEach(x=>x.classList.toggle('on',x.dataset.h===hot));const pct={recharge:32,boost:68,overtake:100}[energyMode],bar=document.getElementById('energybar'),text=document.getElementById('energyText');if(bar)bar.style.width=pct+'%';if(text)text.textContent={recharge:'Prioritises energy recovery and battery state.',boost:'Driver-requested maximum power deployment where permitted.',overtake:'Extra deployment opportunity when sporting eligibility conditions are met.'}[energyMode]};
carCard=function(team,pts){const t=TEAMS[team],drivers=S.drivers.filter(d=>d.team===team);return `<article class="carcard team-glow" style="--team:${t.color}"><div style="display:flex;justify-content:space-between"><h3 style="margin:0">${t.chassis}</h3><b class="team-text">${t.name.split(' ')[0]}</b></div><div class="car-visual">${carSVG(t.color)}</div><div class="specrow"><span>Power unit</span><b>${t.pu}</b></div><div class="specrow"><span>Drivers</span><b class="team-text">${drivers.map(d=>d.code).join(' · ')}</b></div><div class="specrow"><span>Championship points</span><b>${pts}</b></div><div class="specrow"><span>Shared regulation envelope</span><b>1,900 mm · 3,400 mm</b></div></article>`};

/* ---------- simulator V3 ---------- */
function ccSimOptions(sel){return `<option value="">— Select driver —</option>${official().map(d=>`<option value="${d.code}" ${d.code===sel?'selected':''}>${d.code} · ${d.name} · ${TEAMS[d.team].name.split(' ')[0]}</option>`).join('')}`}
function ccSession(r,kind){if(kind==='sprint'){if(!ccSimSprint[r])ccSimSprint[r]=Array(8).fill('');return ccSimSprint[r]}if(!S.sim[r])S.sim[r]=Array(10).fill('');return S.sim[r]}
function ccPositionRow(r,kind,c,i){const d=D(c),points=kind==='sprint'?SP[i]:GP[i],team=d?T(d).color:'var(--line)';return `<div class="sim-pos ${d?'selected':''}" style="--team:${team}" data-row="${r}-${kind}-${i}"><label>${kind==='sprint'?'S':'P'}${i+1}</label><span class="sim-dot" style="background:${d?team:'var(--line)'}"></span><select class="simsel" data-r="${r}" data-kind="${kind}" data-p="${i}">${ccSimOptions(c)}</select><span class="sim-points"><b>+${points}</b>${d?`P${official().findIndex(x=>x.code===d.code)+1}`:'open'}</span></div>`}
simRace=function(r,open){const gp=ccSession(r.r,'gp'),sprint=r.sprint?ccSession(r.r,'sprint'):null,accent=gp[0]?T(D(gp[0])).color:'var(--line)';return `<details class="srace" data-r="${r.r}" style="--race-accent:${accent}" ${open?'open':''}><summary><span>${r.flag}</span><span>R${r.r} · ${r.name}</span>${r.sprint?'<span class="pill sprint">Sprint</span>':''}<span class="srace-summary-meta" id="sum-${r.r}"></span></summary><div class="inside"><div class="sim-session-title">Grand Prix · top 10</div>${gp.map((c,i)=>ccPositionRow(r.r,'gp',c,i)).join('')}${r.sprint?`<div class="sim-session-title">Sprint · top 8</div>${sprint.map((c,i)=>ccPositionRow(r.r,'sprint',c,i)).join('')}`:''}</div></details>`}
function ccUpdateSelectionVisual(r,kind){const arr=ccSession(r,kind);arr.forEach((c,i)=>{const row=document.querySelector(`[data-row="${r}-${kind}-${i}"]`);if(!row)return;const d=D(c),team=d?T(d).color:'var(--line)';row.style.setProperty('--team',team);row.classList.toggle('selected',!!d);const dot=row.querySelector('.sim-dot');if(dot)dot.style.background=d?team:'var(--line)';const p=row.querySelector('.sim-points'),points=kind==='sprint'?SP[i]:GP[i];if(p)p.innerHTML=`<b>+${points}</b>${d?`P${official().findIndex(x=>x.code===d.code)+1}`:'open'}`});ccUpdateRaceSummary(r)}
function ccUpdateRaceSummary(r){const gp=ccSession(r,'gp'),sp=(S.races.find(x=>x.r===r)?.sprint)?ccSession(r,'sprint'):[],el=document.getElementById('sum-'+r),details=document.querySelector(`details[data-r="${r}"]`),winner=D(gp[0]);if(el)el.textContent=`${gp.filter(Boolean).length}/10 GP${sp.length?' · '+sp.filter(Boolean).length+'/8 Sprint':''}${winner?' · '+winner.code+' leads':''}`;if(details)details.style.setProperty('--race-accent',winner?T(winner).color:'var(--line)')}
pick=function(e){const r=+e.target.dataset.r,kind=e.target.dataset.kind,p=+e.target.dataset.p,v=e.target.value,arr=ccSession(r,kind);if(v){const old=arr.indexOf(v);if(old>=0&&old!==p){arr[old]='';const oldSel=document.querySelector(`.simsel[data-r="${r}"][data-kind="${kind}"][data-p="${old}"]`);if(oldSel)oldSel.value=''}}arr[p]=v;ccUpdateSelectionVisual(r,kind);drawSim();ccMarkDirty()};
function ccSimTotals(sim=S.sim,sprints=ccSimSprint){const totals={},wins={},podiums={};S.drivers.forEach(d=>{totals[d.code]=d.pts;wins[d.code]=d.stats.wins;podiums[d.code]=d.stats.podiums});Object.values(sim||{}).forEach(arr=>(arr||[]).forEach((c,i)=>{if(c&&totals[c]!=null){totals[c]+=GP[i]||0;if(i===0)wins[c]++;if(i<3)podiums[c]++}}));Object.values(sprints||{}).forEach(arr=>(arr||[]).forEach((c,i)=>{if(c&&totals[c]!=null)totals[c]+=SP[i]||0}));const rows=S.drivers.map(d=>({...d,projected:totals[d.code],projectedWins:wins[d.code],projectedPodiums:podiums[d.code]})).sort((a,b)=>b.projected-a.projected||b.pts-a.pts);return {totals,wins,podiums,rows}}
function ccConstructorsProjected(rows){const m={};rows.forEach(d=>m[d.team]=(m[d.team]||0)+d.projected);return Object.entries(m).map(([team,pts])=>({team,pts})).sort((a,b)=>b.pts-a.pts)}
function ccImpactCards(code){return S.races.filter(r=>!r.done).map(r=>{const gp=S.sim[r.r]||[],p=gp.indexOf(code);return `<div class="impact-race"><small>${r.flag} R${r.r}</small><b>${p>=0?'P'+(p+1):'—'}</b><small>${p>=0?'+'+GP[p]+' pts':'not set'}</small></div>`}).join('')}
function ccRankPercent(rank){return ((22-rank)/21*100).toFixed(1)}
function ccFocusPanel(rows){const d=D(ccSimFocus)||official()[0],current=official().findIndex(x=>x.code===d.code)+1,projected=rows.findIndex(x=>x.code===d.code)+1,row=rows.find(x=>x.code===d.code),leader=rows[0],added=row.projected-d.pts,gap=row.code===leader.code?0:leader.projected-row.projected;return `<div class="focus-card" style="--team:${T(d).color}"><div class="focus-head"><div class="focus-avatar">${d.code}</div><div class="focus-name"><b>${d.nat} ${esc(d.name)}</b><div class="mut">${TEAMS[d.team].name}</div></div><b class="team-text">#${d.num}</b></div><div class="focus-kpis"><div class="focus-kpi"><b>P${current} → P${projected}</b><span>rank movement</span></div><div class="focus-kpi"><b>${row.projected}</b><span>projected points</span></div><div class="focus-kpi"><b>+${added}</b><span>scenario points</span></div><div class="focus-kpi"><b>${gap?'-'+gap:'LEAD'}</b><span>leader gap</span></div></div><div class="rank-track"><i class="rank-dot" style="left:${ccRankPercent(projected)}%"></i></div><div class="rank-caption">Moving championship index · P22 on the left, P1 on the right</div><div class="meta"><span>Projected wins <b>${row.projectedWins}</b></span><span>Projected podiums <b>${row.projectedPodiums}</b></span></div><div class="impact-strip">${ccImpactCards(d.code)}</div></div>`}
function ccProjectedTable(rows){const off=official(),leader=rows[0].projected;return `<div class="projected">${rows.slice(0,14).map((d,i)=>{const old=off.findIndex(x=>x.code===d.code)+1,rank=i+1,delta=old-rank;return `<div class="rank-row ${d.code===ccSimFocus?'focused':''}" style="--team:${T(d).color}" data-code="${d.code}"><i class="rank-bar" style="width:${d.projected/leader*100}%"></i><b>${rank}</b><span class="rank-team"></span><span><b>${esc(d.name)}</b><small class="mut"> ${d.code} · ${TEAMS[d.team].name.split(' ')[0]}</small></span><span class="rank-delta ${delta>0?'up':delta<0?'down':''}">${delta>0?'▲ '+delta:delta<0?'▼ '+(-delta):'—'}</span><span class="rank-points">${d.projected}</span></div>`}).join('')}</div>`}
function ccAnimateRanks(rows){requestAnimationFrame(()=>{document.querySelectorAll('.rank-row').forEach(el=>{const code=el.dataset.code,newIndex=rows.findIndex(x=>x.code===code),oldIndex=ccPrevRanks[code];if(oldIndex!=null&&oldIndex!==newIndex){el.style.transition='none';el.style.transform=`translateY(${(oldIndex-newIndex)*45}px)`;requestAnimationFrame(()=>{el.style.transition='transform .48s var(--ease),background .25s';el.style.transform='translateY(0)'})}});ccPrevRanks=Object.fromEntries(rows.map((d,i)=>[d.code,i]))})}
function ccVaultSummary(slot){const v=ccVault[slot];if(!v)return `<div class="vault-card" style="--accent:var(--dim)"><b>Scenario ${slot}</b><span>Empty slot</span></div>`;const result=ccSimTotals(v.sim,v.sprint),lead=result.rows[0],margin=lead.projected-result.rows[1].projected;return `<div class="vault-card" style="--accent:${T(lead).color}"><b>Scenario ${slot} · ${lead.code}</b><span>${lead.projected} pts · +${margin} lead</span></div>`}
function ccUpdateVaultCards(){const box=document.getElementById('vaultCards');if(box)box.innerHTML=['A','B','C'].map(ccVaultSummary).join('')}
function ccSaveScenario(){const slot=document.getElementById('vaultSlot').value;ccVault[slot]={sim:ccDeep(S.sim),sprint:ccDeep(ccSimSprint),focus:ccSimFocus,savedAt:new Date().toISOString()};ccMarkDirty();ccUpdateVaultCards();ccToast(`Scenario ${slot} captured`)}
function ccLoadScenario(){const slot=document.getElementById('vaultSlot').value,v=ccVault[slot];if(!v){ccToast(`Scenario ${slot} is empty`);return}S.sim=ccDeep(v.sim);ccSimSprint=ccDeep(v.sprint||{});ccSimFocus=v.focus||ccSimFocus;ccMarkDirty();renderSim();ccToast(`Scenario ${slot} loaded`)}
function ccClearScenario(){const slot=document.getElementById('vaultSlot').value;ccVault[slot]=null;ccMarkDirty();ccUpdateVaultCards();ccToast(`Scenario ${slot} cleared`)}
function ccFillCurrent(){const order=official().map(d=>d.code);S.races.filter(r=>!r.done).forEach(r=>{S.sim[r.r]=order.slice(0,10);if(r.sprint)ccSimSprint[r.r]=order.slice(0,8)});ccMarkDirty();renderSim()}
function ccFillFocusWins(){const order=official().map(d=>d.code).filter(c=>c!==ccSimFocus);S.races.filter(r=>!r.done).forEach((r,idx)=>{const rotated=[...order.slice(idx%5),...order.slice(0,idx%5)];S.sim[r.r]=[ccSimFocus,...rotated].slice(0,10);if(r.sprint)ccSimSprint[r.r]=[ccSimFocus,...rotated].slice(0,8)});ccMarkDirty();renderSim()}
function ccClearSimulation(){S.sim={};ccSimSprint={};ccMarkDirty();renderSim()}
renderSim=function(){const left=S.races.filter(r=>!r.done),focusOpts=official().map(d=>`<option value="${d.code}">${d.code} · ${d.name}</option>`).join('');document.querySelector('#sim').innerHTML=`<h2>Championship simulator<span class="sub">animated rankings · driver impact · GP and Sprint scoring</span></h2><div class="note">Select finishers for every remaining Grand Prix and Sprint. The right panel shows how each choice changes a selected driver's rank, points, wins, podiums and title gap. Fastest laps, penalties and unconfirmed classifications are not invented.</div><div class="sim-toolbar"><div class="control"><label>Driver Focus</label><select id="simFocus">${focusOpts}</select></div><button class="smallbtn" id="form">Fill by current order</button><button class="smallbtn" id="focusWins">Focus driver wins</button><button class="smallbtn action-danger" id="simReset">Clear simulation</button></div><div class="panel" style="margin-bottom:12px"><div class="controls"><div class="control"><label>Scenario Vault <span class="new-flag">New</span></label><select id="vaultSlot"><option>A</option><option>B</option><option>C</option></select></div><button class="smallbtn" id="saveScenario">Save scenario</button><button class="smallbtn" id="loadScenario">Load scenario</button><button class="smallbtn" id="clearScenario">Clear slot</button></div><div class="scenario-vault" id="vaultCards"></div></div><div class="simgrid"><div id="simr">${left.map((r,idx)=>simRace(r,idx===0)).join('')}</div><div class="simboard"><div id="focusPanel"></div><h2 style="margin-top:10px">Projected standings<span class="sub">rows move as selections change</span></h2><div id="simtower"></div><h2>Projected constructors</h2><div id="simconstructors"></div></div></div>`;const focus=document.getElementById('simFocus');focus.value=ccSimFocus;focus.onchange=()=>{ccSimFocus=focus.value;ccMarkDirty();drawSim()};document.querySelectorAll('.simsel').forEach(s=>s.onchange=pick);document.getElementById('form').onclick=ccFillCurrent;document.getElementById('focusWins').onclick=ccFillFocusWins;document.getElementById('simReset').onclick=ccClearSimulation;document.getElementById('saveScenario').onclick=ccSaveScenario;document.getElementById('loadScenario').onclick=ccLoadScenario;document.getElementById('clearScenario').onclick=ccClearScenario;left.forEach(r=>ccUpdateRaceSummary(r.r));ccUpdateVaultCards();drawSim()};
drawSim=function(){const data=ccSimTotals(),rows=data.rows,focus=document.getElementById('focusPanel'),towerEl=document.getElementById('simtower'),constructorsEl=document.getElementById('simconstructors');if(focus)focus.innerHTML=ccFocusPanel(rows);if(towerEl)towerEl.innerHTML=ccProjectedTable(rows);if(constructorsEl){const cs=ccConstructorsProjected(rows),lead=cs[0].pts;constructorsEl.innerHTML=`<div class="projected">${cs.map((c,i)=>`<div class="rank-row" style="--team:${TEAMS[c.team].color}"><i class="rank-bar" style="width:${c.pts/lead*100}%"></i><b>${i+1}</b><span class="rank-team"></span><span><b>${TEAMS[c.team].name}</b></span><span class="rank-delta"></span><span class="rank-points">${c.pts}</span></div>`).join('')}</div>`}ccAnimateRanks(rows)};

/* ---------- boot and state integration ---------- */
ccAddHeaderControls();
ccLoadSaved();
renderAll=function(){renderOverview();renderStandings();renderRaces();renderTeams();renderCars();renderSim()};
const navEl=document.getElementById('nav');navEl.onclick=e=>{const b=e.target.closest('button[data-tab]');if(b)ccSetTab(b.dataset.tab)};
renderAll();ccSetTab(ccActiveTab,false);
window.addEventListener('keydown',e=>{if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='s'){e.preventDefault();ccSave()}});
})();
</script>

