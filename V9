iv><div class="spec"><b>1.6L V6</b><small>turbo-hybrid ICE</small></div></div><div class="note" style="margin-top:12px"><b>Visual source:</b> the car and logo are official Formula 1 media assets. The speed lines, floating motion and energy bar are interface effects, not telemetry claims.</div></div></div><h2>Pit Wall Compare<span class="sub">new feature · compare two teams without invented performance data</span></h2><div class="panel pit-wall"><div class="v4-toolbar"><div class="control"><label>Team A</label><select id="v4CompareA">${teamOptions(V4.compareA)}</select></div><div class="control"><label>Team B</label><select id="v4CompareB">${teamOptions(V4.compareB)}</select></div></div><div id="v4PitCompare">${pitCompare()}</div></div><h2>2026 team car directory<span class="sub">official images · four-column compact layout</span></h2><div class="car-directory-v4">${constructors().map(c=>carCardV4(c.team,c.pts)).join('')}</div>`;document.getElementById('v4CarTeam').onchange=e=>{V4.carTeam=e.target.value;V4.autoTour=false;clearInterval(tourTimer);markDirty();renderCars()};document.getElementById('v4AutoTour').onclick=()=>{V4.autoTour=!V4.autoTour;markDirty();renderCars();startTour()};document.querySelectorAll('[data-a]').forEach(b=>b.onclick=()=>{aero=b.dataset.a;markDirty();renderCars()});document.querySelectorAll('[data-e]').forEach(b=>b.onclick=()=>{energyMode=b.dataset.e;markDirty();renderCars()});document.querySelectorAll('[data-h]').forEach(b=>b.onclick=()=>{hot=b.dataset.h;markDirty();updateCarInfo()});target.querySelectorAll('[data-car-team]').forEach(b=>b.onclick=()=>{V4.carTeam=b.dataset.carTeam;V4.autoTour=false;clearInterval(tourTimer);markDirty();renderCars();target.scrollIntoView({behavior:'smooth',block:'start'})});document.getElementById('v4CompareA').onchange=e=>{V4.compareA=e.target.value;markDirty();document.getElementById('v4PitCompare').innerHTML=pitCompare()};document.getElementById('v4CompareB').onchange=e=>{V4.compareB=e.target.value;markDirty();document.getElementById('v4PitCompare').innerHTML=pitCompare()};updateCarInfo()};
function addCompactToggle(){const actions=document.querySelector('.header-actions')||document.querySelector('.status');if(!actions||document.getElementById('v4Compact'))return;const b=document.createElement('button');b.id='v4Compact';b.className='ghost v4-header-toggle'+(V4.compact?' on':'');b.textContent='▦ Compact';b.title='Reduce card height and page scrolling';b.onclick=()=>{V4.compact=!V4.compact;document.body.classList.toggle('compact-ui',V4.compact);b.classList.toggle('on',V4.compact);markDirty()};actions.insertBefore(b,actions.firstChild)}
function integrateSaveReset(){const save=document.getElementById('ccSave'),reset=document.getElementById('ccReset');if(save&&!save.dataset.v4){save.dataset.v4='1';const old=save.onclick;save.onclick=e=>{if(old)old.call(save,e);saveV4()}}if(reset&&!reset.dataset.v4){reset.dataset.v4='1';const old=reset.onclick;reset.onclick=e=>{let accepted=false;const nativeConfirm=window.confirm;window.confirm=msg=>{accepted=nativeConfirm(msg);return accepted};try{if(old)old.call(reset,e)}finally{window.confirm=nativeConfirm}if(accepted){resetV4();renderTeams();renderCars()}}}}
document.title='F1 2026 · Singapore Command Centre V4';document.body.classList.toggle('compact-ui',V4.compact);addCompactToggle();integrateSaveReset();const active=document.querySelector('.tab.on')?.id;if(active==='teams')renderTeams();if(active==='cars')renderCars();
})();
</script>


