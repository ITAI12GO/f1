drawChart=function(){const box=document.getElementById('chart');if(!box)return;const done=S.races.filter(r=>r.done),drivers=S.selected.map(D).filter(Boolean);if(!drivers.length){box.innerHTML='<div class="note">Select at least one driver. Up to eight can be mixed in the same chart.</div>';document.getElementById('chartReadout').innerHTML='';return}const metric=S.metric,mode=S.mode,W=1000,H=410,P={l:54,r:118,t:24,b:54};const teamSeen={};const series=drivers.map(d=>{let vals=[...d.progress[metric]];if(mode==='round')vals=vals.map((v,i)=>i?Math.max(0,v-vals[i-1]):0);if(mode==='normalized'){const own=Math.max(...vals,1);vals=vals.map(v=>v/own*100)}const teammateIndex=teamSeen[d.team]||0;teamSeen[d.team]=teammateIndex+1;return {d,vals,teammateIndex}});const max=Math.max(...series.flatMap(s=>s.vals),1);const x=i=>P.l+(W-P.l-P.r)*i/Math.max(done.length,1),y=v=>H-P.b-(H-P.t-P.b)*v/max;series.forEach(s=>s.points=s.vals.map((v,i)=>({x:x(i),y:y(v),v})));let labels=series.map(s=>({s,y:s.points.at(-1).y,actual:s.points.at(-1).y})).sort((a,b)=>a.y-b.y);const minGap=18;for(let i=1;i<labels.length;i++)labels[i].y=Math.max(labels[i].y,labels[i-1].y+minGap);const maxY=H-P.b-6;if(labels.at(-1).y>maxY){const shift=labels.at(-1).y-maxY;labels.forEach(l=>l.y-=shift)}for(let i=labels.length-2;i>=0;i--)labels[i].y=Math.min(labels[i].y,labels[i+1].y-minGap);const minY=P.t+5;if(labels[0].y<minY){const shift=minY-labels[0].y;labels.forEach(l=>l.y+=shift)}let svg=`<svg viewBox="0 0 ${W} ${H}" role="img" aria-label="Driver progression chart">`;for(let g=0;g<=5;g++){const v=max*g/5;svg+=`<line x1="${P.l}" x2="${W-P.r}" y1="${y(v)}" y2="${y(v)}" stroke="#2a303c"/><text x="6" y="${y(v)+4}" fill="#788396" font-size="11">${mode==='normalized'?Math.round(v)+'%':Math.round(v)}</text>`}const tickStep=Math.max(1,Math.ceil(done.length/7));svg+=`<text x="${P.l}" y="${H-18}" fill="#788396" font-size="10" text-anchor="middle">START</text>`;done.forEach((r,i)=>{const idx=i+1;if(idx%tickStep!==0&&idx!==done.length)return;svg+=`<text x="${x(idx)}" y="${H-23}" fill="#8d97a8" font-size="10" text-anchor="middle"><tspan x="${x(idx)}">R${r.r}</tspan><tspan x="${x(idx)}" dy="13">${ccShortRace(r)}</tspan></text>`});series.forEach(s=>{const colour=T(s.d).color,dash=s.teammateIndex%2?'10 7':'';svg+=`<path d="${ccSmoothPath(s.points)}" fill="none" stroke="${colour}" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" ${dash?`stroke-dasharray="${dash}"`:''} opacity=".96"/>`;s.points.forEach((p,i)=>svg+=`<circle class="chart-hit" data-code="${s.d.code}" data-i="${i}" cx="${p.x}" cy="${p.y}" r="9" fill="transparent"/>`)});labels.forEach(l=>{const end=l.s.points.at(-1),colour=T(l.s.d).color;svg+=`<path d="M${end.x+3},${end.y} C${end.x+24},${end.y} ${W-P.r+8},${l.y} ${W-P.r+18},${l.y}" fill="none" stroke="${colour}" stroke-width="1.4" opacity=".7"/><text x="${W-P.r+23}" y="${l.y+4}" fill="${colour}" font-size="11" font-weight="800">${l.s.d.code}</text>`});svg+=`<line id="ccCrosshair" class="chart-crosshair" x1="${x(ccChartIndex)}" x2="${x(ccChartIndex)}" y1="${P.t}" y2="${H-P.b}" stroke="#d9dee7" stroke-width="1" stroke-dasharray="4 5" opacity=".38"/>`;series.forEach(s=>{const p=s.points[Math.min(ccChartIndex,s.points.length-1)];svg+=`<circle id="ccMarker-${s.d.code}" class="chart-marker" cx="${p.x}" cy="${p.y}" r="6" fill="${T(s.d).color}" stroke="#090b10" stroke-width="2" style="color:${T(s.d).color}"/>`});svg+='</svg><div class="tooltip" id="tip"></div>';box.innerHTML=svg;box.insertAdjacentHTML('beforebegin',`<div class="chart-legend" id="ccLegend">${series.map(s=>`<span><i style="background:${T(s.d).color}"></i>${s.d.code}${s.teammateIndex%2?' · dashed':''}</span>`).join('')}</div>`);const oldLegend=box.parentElement.querySelectorAll('#ccLegend');if(oldLegend.length>1)oldLegend[0].remove();ccChartModel={series,done,x,y};const tip=box.querySelector('#tip');box.querySelectorAll('.chart-hit').forEach(c=>{c.onmouseenter=()=>{const s=series.find(v=>v.d.code===c.dataset.code),idx=+c.dataset.i;tip.style.display='block';tip.innerHTML=`<b style="color:${T(s.d).color}">${esc(s.d.name)}</b><br>${idx?done[idx-1].name:'Season start'}<br>${metric}: ${Number(s.vals[idx]).toFixed(mode==='normalized'?1:0)}${mode==='normalized'?'%':''}`};c.onmousemove=e=>{const rect=box.getBoundingClientRect();tip.style.left=(e.clientX-rect.left+12)+'px';tip.style.top=(e.clientY-rect.top+10)+'px'};c.onmouseleave=()=>tip.style.display='none'});ccMoveChartIndex()};
function ccMoveChartIndex(){if(!ccChartModel)return;const {series,done,x}=ccChartModel;ccChartIndex=Math.max(0,Math.min(ccChartIndex,done.length));const line=document.getElementById('ccCrosshair');if(line){line.setAttribute('x1',x(ccChartIndex));line.setAttribute('x2',x(ccChartIndex))}series.forEach(s=>{const p=s.points[Math.min(ccChartIndex,s.points.length-1)],m=document.getElementById('ccMarker-'+s.d.code);if(m){m.setAttribute('cx',p.x);m.setAttribute('cy',p.y)}});const now=document.getElementById('roundNow');if(now)now.textContent=ccChartIndex===0?'Season start':`R${done[ccChartIndex-1].r} · ${done[ccChartIndex-1].name}`;const read=document.getElementById('chartReadout');if(read)read.innerHTML=series.map(s=>{const val=s.vals[Math.min(ccChartIndex,s.vals.length-1)],prev=ccChartIndex?s.vals[ccChartIndex-1]:val,delta=val-prev;return `<div class="chart-read-card" style="--team:${T(s.d).color}"><small>${s.d.code} · ${esc(s.d.name)}</small><b>${Number(val).toFixed(S.mode==='normalized'?1:0)}${S.mode==='normalized'?'%':''}</b><small>${ccChartIndex?`${delta>=0?'+':''}${Number(delta).toFixed(S.mode==='normalized'?1:0)} this round`:'baseline'}</small></div>`}).join('')}
drawH2H=function(){const box=document.getElementById('h2h'),xD=D(S.h2h[0]),yD=D(S.h2h[1]);if(!box||!xD||!yD)return;const stats=[['Points','pts'],['Wins','wins'],['Podiums','podiums'],['Poles','poles'],['Top 10s','top10']];box.innerHTML=`<div class="h2h-grid"><div class="h2h-person team-identity" style="--team:${T(xD).color}"><b class="team-text">${xD.nat} ${xD.name}</b><div class="mut">${TEAMS[xD.team].name}</div></div><div class="h2h-person team-identity" style="--team:${T(yD).color}"><b class="team-text">${yD.nat} ${yD.name}</b><div class="mut">${TEAMS[yD.team].name}</div></div></div>${stats.map(([n,k])=>{const xv=k==='pts'?xD.pts:xD.stats[k],yv=k==='pts'?yD.pts:yD.stats[k],m=Math.max(xv,yv,1);return `<div class="compare-row"><b>${n}</b><div><div class="bar"><i style="width:${xv/m*100}%;background:${T(xD).color}"></i></div><div class="bar" style="margin-top:4px"><i style="width:${yv/m*100}%;background:${T(yD).color}"></i></div></div><span class="mono">${xv}/${yv}</span></div>`}).join('')}`};

